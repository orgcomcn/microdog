generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum LockStatus {
  ACTIVE
  RELEASED
}

model User {
  id              String      @id @default(cuid())
  uid             String?     @unique
  inviteCode      String?     @unique
  walletAddress   String      @unique
  nickname        String?
  avatar          String?
  role            UserRole    @default(USER)
  pointsBalance   Int         @default(0)
  invitedByUserId String?
  referralBoundAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  invitedBy       User?       @relation("UserReferrals", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  referrals       User[]      @relation("UserReferrals")
  pointsLedger    PointLog[]
  lockPositions   LockPosition[]
  authSessions    AuthSession[]

  @@index([invitedByUserId, createdAt])
}

model AuthSession {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  walletAddress String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([walletAddress])
}

model PointLog {
  id          String   @id @default(cuid())
  userId      String
  change      Int
  reason      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LockPosition {
  id          String     @id @default(cuid())
  userId      String
  assetSymbol String
  amount      Decimal    @db.Decimal(18, 6)
  status      LockStatus @default(ACTIVE)
  startAt     DateTime   @default(now())
  endAt       DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
