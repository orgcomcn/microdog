generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  FROZEN
}

enum LockStatus {
  ACTIVE
  RELEASED
}

enum PointLogType {
  REGISTER_REWARD
  INVITE_REWARD
  ACTIVITY_REWARD
  MANUAL_GRANT
  MANUAL_DEDUCT
  LOCK_REWARD
  SYSTEM_ADJUST
}

enum PredictionSymbol {
  BTC
  ETH
}

enum PredictionDirection {
  UP
  DOWN
}

enum PredictionStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  EXPIRED
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model User {
  id              String      @id @default(cuid())
  uid             String?     @unique
  inviteCode      String?     @unique
  walletAddress   String      @unique
  nickname        String?
  avatar          String?
  role            UserRole    @default(USER)
  status          UserStatus  @default(ACTIVE)
  pointsBalance   Int         @default(0)
  invitedByUserId String?
  referralBoundAt DateTime?
  frozenAt        DateTime?
  frozenReason    String?
  lastLoginAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  invitedBy       User?       @relation("UserReferrals", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  referrals       User[]      @relation("UserReferrals")
  pointsLedger    PointLog[]
  lockPositions   LockPosition[]
  authSessions    AuthSession[]

  @@index([invitedByUserId, createdAt])
  @@index([status, createdAt])
}

model AuthSession {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  walletAddress String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([walletAddress])
}

model AdminSession {
  id         String   @id @default(cuid())
  username   String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([username, expiresAt])
}

model PointLog {
  id            String       @id @default(cuid())
  userId        String
  change        Int
  balanceAfter  Int
  type          PointLogType @default(ACTIVITY_REWARD)
  reason        String
  operatorLabel String?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model LockPosition {
  id              String     @id @default(cuid())
  userId          String
  assetSymbol     String
  amount          Decimal    @db.Decimal(18, 6)
  durationDays    Int        @default(30)
  releaseRatioBps Int        @default(10000)
  status          LockStatus @default(ACTIVE)
  startAt         DateTime   @default(now())
  endAt           DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Prediction {
  id             String              @id @default(cuid())
  symbol         PredictionSymbol
  direction      PredictionDirection
  targetPrice    Decimal             @db.Decimal(18, 2)
  publishAt      DateTime
  effectiveUntil DateTime
  status         PredictionStatus    @default(DRAFT)
  summary        String?
  createdBy      String
  updatedBy      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([symbol, status, publishAt])
  @@index([publishAt, effectiveUntil])
}

model Announcement {
  id          String             @id @default(cuid())
  title       String
  tag         String?
  content     String
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?
  sortOrder   Int                @default(0)
  createdBy   String
  updatedBy   String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status, publishedAt, sortOrder])
}

model SystemConfig {
  id                   String   @id @default("default")
  registerRewardPoints Int      @default(100)
  inviteRewardPoints   Int      @default(50)
  aiDailyQuestionLimit Int      @default(10)
  btcAmount            Decimal  @default(0) @db.Decimal(24, 8)
  ethAmount            Decimal  @default(0) @db.Decimal(24, 8)
  microdogAmount       Decimal  @default(0) @db.Decimal(30, 8)
  tvl                  Decimal  @default(0) @db.Decimal(24, 2)
  assetPoolUpdatedAt   DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model LockPlanConfig {
  id              String   @id @default(cuid())
  name            String
  durationDays    Int      @unique
  releaseRatioBps Int      @default(10000)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, sortOrder])
}
