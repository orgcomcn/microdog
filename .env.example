# PostgreSQL connection used by Next.js API routes and Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/microdog_v1?schema=public"

# WalletConnect project id. Replace before enabling real wallet login.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="replace-with-project-id"

# Public app name shown in the wallet UI.
NEXT_PUBLIC_APP_NAME="MicroDOG V1"

# Admin login for backend management.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Optional CoinGecko API key. Demo key is enough for this project in early stage.
COINGECKO_API_KEY=""

# Optional CoinGecko base url. Keep default unless you use Pro.
COINGECKO_API_BASE_URL="https://api.coingecko.com/api/v3"

# P已经被 CoinGecko 当成一个正式币种收录
MARKET_MICRODOGE_COINGECKO_ID=""

# 还没有独立 coin id，但 CoinGecko 能识别这个链上 token
MARKET_MICRODOGE_PLATFORM_ID=""
MARKET_MICRODOGE_CONTRACT_ADDRESS=""
