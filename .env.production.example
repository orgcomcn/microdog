# PostgreSQL 容器配置。
POSTGRES_DB="microdog_v1"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me-strong-password"

# Docker 内部数据库连接串，host 必须保持为 db。
DATABASE_URL="postgresql://postgres:change-me-strong-password@db:5432/microdog_v1?schema=public"

# Caddy 自动申请 HTTPS 证书时使用的域名和邮箱。
APP_DOMAIN="your-domain.com"
ACME_EMAIL="admin@your-domain.com"

# WalletConnect 项目 ID，正式启用钱包登录前需要替换。
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="replace-with-project-id"

# 钱包连接弹窗里展示的应用名称。
NEXT_PUBLIC_APP_NAME="MicroDOG V1"

# 后台管理员登录账号和密码。
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-admin-password"

# CoinGecko API Key，可选；早期 Demo Key 就够用。
COINGECKO_API_KEY=""

# CoinGecko API 基础地址；不用 Pro 时保持默认即可。
COINGECKO_API_BASE_URL="https://api.coingecko.com/api/v3"

# 如果 MicroDOGE 已经被 CoinGecko 当成正式币种收录，填写 coin id。
MARKET_MICRODOGE_COINGECKO_ID=""

# 如果还没有独立 coin id，但 CoinGecko 能识别链上 token，填写链平台 id 和合约地址。
MARKET_MICRODOGE_PLATFORM_ID=""
MARKET_MICRODOGE_CONTRACT_ADDRESS=""
